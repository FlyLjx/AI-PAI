{
  "name": "ai-pai-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/admin"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n web,admin,go -c green,magenta,cyan \"npm:dev:web\" \"npm:dev:admin\" \"npm:dev:go\"",
    "dev:local": "powershell -ExecutionPolicy Bypass -File dev.ps1",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File dev-stop.ps1",
    "dev:web": "npm run dev --workspace @aipai/web",
    "dev:admin": "npm run dev --workspace @aipai/admin",
    "dev:go": "powershell -ExecutionPolicy Bypass -File scripts/dev-go-watch.ps1 -Port 3001",
    "build": "npm run build:web && npm run build:admin && npm run build:go",
    "build:web": "npm run build --workspace @aipai/web",
    "build:admin": "npm run build --workspace @aipai/admin",
    "build:go": "powershell -ExecutionPolicy Bypass -File scripts/build-go.ps1",
    "start": "concurrently --kill-others-on-fail -n web,admin -c green,magenta \"npm:start:web\" \"npm:start:admin\"",
    "start:web": "npm run start --workspace @aipai/web",
    "start:admin": "npm run start --workspace @aipai/admin",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:go": "go -C go-server test ./...",
    "check": "npm run lint && npm run typecheck && npm run build:web && npm run build:admin"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
